# =====================================================================
# FinUp — variáveis de ambiente
# Copie pra .env.local e preencha os valores REAIS.
# .env.local nunca vai pro git (já está no .gitignore).
# =====================================================================

# Supabase
# Você pega esses dois valores em: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...sua-anon-key-publica...

# (Opcional) URL pública da app pra emails de confirmação/recovery
# Em produção, coloca a URL real (ex: https://finup.app)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
